{
  "name": "@memgrafter/opencode-flatmachines",
  "version": "4.1.0",
  "description": "OpenCode plugin that exposes FlatMachines validation and execution as native tools",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "opencode.example.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "flatmachines",
    "orchestration",
    "agents",
    "state-machine"
  ],
  "author": "memgrafter@gmail.com",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "opencode": ">=1.15.13"
  },
  "dependencies": {
    "@memgrafter/flatmachines": "^4.0.1",
    "@opencode-ai/plugin": "^1.15.13",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.8",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
